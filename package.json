{
  "name": "gitban_agent",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "web-ui",
    "src"
  ],
  "scripts": {
    "dev": "npm run dev:server & npm run dev:web",
    "dev:server": "tsx watch src/cli.ts",
    "dev:web": "npm --prefix web-ui run dev",
    "build": "npm run build:web && npm run build:server",
    "build:web": "npm --prefix web-ui run build",
    "build:server": "tsc -p tsconfig.json",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
